# Backend Environment Variables
# These variables act as the default fallback if no connection string is provided by the UI.
# 
# Option A: Full Connection String
# DATABASE_URL="postgresql://user:password@localhost:5432/supply_chain"
# For Neon DB, don't forget to append ?sslmode=require
# DATABASE_URL="postgresql://user:password@ep-cool-db.aws.neon.tech/neondb?sslmode=require"

# Option B: Component Variables (Parsed automatically)
PG_HOST="localhost"
PG_PORT="5432"
PG_DB="postgres"
PG_USER="postgres"
PG_PASSWORD=""
